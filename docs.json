{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Xenovia",
  "logo": {
    "light": "/logo/icon.png",
    "dark": "/logo/icon.png",
    "href": "https://xenovia.io"
  },
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#1B1033"
  },
  "favicon": "/logo/icon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Start Here",
            "pages": [
              "introduction",
              "getting-started/overview",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/overview",
              "integrations/xenovia-sdk",
              "integrations/openai-sdk",
              "integrations/langchain",
              "integrations/llamaindex",
              "integrations/openai-agents-sdk",
              "integrations/vercel-ai-sdk",
              "integrations/autogen-crewai"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/overview",
              "platform/runtime-architecture",
              "platform/policies-and-approvals",
              "platform/tools-and-access",
              "platform/traces-and-remediation"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/errors-and-limits"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": {
              "source": "https://cp.xenovia.io/openapi.json",
              "directory": "api-reference"
            }
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:richard.loomis@xenovia.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Platform",
      "href": "https://app.xenovia.io/"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/xenovia_io",
      "linkedin": "https://www.linkedin.com/company/xenovia"
    }
  }
}