            "group": "Start Here",
            "pages": [
              "introduction",
              "getting-started/overview",
              "getting-started/quickstart"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/overview",
              "platform/runtime-architecture",
              "platform/policies-and-approvals",
              "platform/tools-and-access",
              "platform/traces-and-remediation"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core API",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication",
              "api-reference/errors-and-limits"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": {
              "source": "https://carbon-api-806155479073.us-central1.run.app/openapi.json",
              "directory": "api-reference"
